        <div class="swatch" style="background:#3A1A1A" data-c="#3A1A1A" onclick="pickColor(this)"></div>
        <div class="swatch" style="background:#2D2340" data-c="#2D2340" onclick="pickColor(this)"></div>
        <div class="swatch" style="background:#3A2D1A" data-c="#3A2D1A" onclick="pickColor(this)"></div>
      </div>
    </div>
    <div class="m-btns">
      <button class="m-btn sec" onclick="closeModal()">Cancel</button>
      <button class="m-btn" onclick="createSerial()">Create</button>
    </div>
  </div>
</div>

<script>
// ============================================================
// STATE
// ============================================================
let serials = JSON.parse(localStorage.getItem('cm_serials')||'[]');
let activeS = null, activeCh = null, selColor = '#1A1208', saveTimer = null;
const ROMAN = ['I','II','III','IV','V','VI','VII','VIII','IX','X','XI','XII','XIII','XIV','XV','XVI','XVII','XVIII','XIX','XX'];

// ============================================================
// COVER — DOOR INTERACTION
// ============================================================
function enterWorld(){
  const door = document.getElementById('door');
  const light = document.getElementById('door-light');
  const flash = document.getElementById('portal-flash');
  const leaf = document.getElementById('page-turn-leaf');
  door.classList.add('open');
  light.classList.add('show');
  setTimeout(()=>{
    // reset and trigger animation
    leaf.style.animation='none';
    leaf.offsetHeight; // reflow
    leaf.style.animation='';
    flash.classList.add('go');
  },520);
  setTimeout(()=>{
    document.getElementById('view-cover').classList.remove('active');
    document.getElementById('view-inner').classList.add('active');
    document.getElementById('view-inner').scrollTop = 0;
    flash.classList.remove('go');
    renderArchive();
  },1350);
}

// fireflies
(function spawnFireflies(){
  const scene = document.getElementById('view-cover');
  const positions = [
    {l:'17%',t:'25%',dl:0,dr:3.5,dx:'14px',dy:'-80px'},
    {l:'23%',t:'38%',dl:1.3,dr:4.2,dx:'-10px',dy:'-100px'},
    {l:'74%',t:'30%',dl:0.6,dr:5.1,dx:'12px',dy:'-90px'},
    {l:'67%',t:'44%',dl:2.0,dr:4.6,dx:'-16px',dy:'-110px'},
    {l:'31%',t:'58%',dl:0.2,dr:3.8,dx:'8px',dy:'-70px'},
    {l:'63%',t:'52%',dl:1.7,dr:5.4,dx:'-8px',dy:'-95px'},
    {l:'43%',t:'32%',dl:3.0,dr:4.0,dx:'10px',dy:'-85px'},
    {l:'54%',t:'62%',dl:0.8,dr:4.9,dx:'-6px',dy:'-75px'},
    {l:'13%',t:'50%',dl:2.3,dr:5.8,dx:'18px',dy:'-120px'},
    {l:'81%',t:'57%',dl:1.0,dr:4.4,dx:'-14px',dy:'-88px'},
    {l:'88%',t:'35%',dl:2.8,dr:3.9,dx:'10px',dy:'-105px'},
    {l:'8%', t:'42%',dl:0.5,dr:6.0,dx:'20px',dy:'-95px'},
  ];
  positions.forEach(p=>{
    const f = document.createElement('div');
    f.className='firefly';
    f.style.cssText=`left:${p.l};top:${p.t};--fdx:${p.dx};--fdy:${p.dy};animation-delay:${p.dl}s;animation-duration:${p.dr}s`;
    scene.appendChild(f);
  });
})();

// platform planks
(function buildPlatform(){
  const pl = document.getElementById('pf-planks');
  if(!pl) return;
  for(let i=0;i<10;i++){
    const d = document.createElement('div');
    d.className='p-plank';
    pl.appendChild(d);
  }
  const rl = document.getElementById('railing');
  if(rl){
    for(let i=0;i<14;i++){
      const p = document.createElement('div');
      p.className='rail-post';
      rl.appendChild(p);
    }
  }
})();

// ============================================================
// INNER SITE
// ============================================================
function showSub(name){
  document.querySelectorAll('.sub-view').forEach(v=>v.classList.remove('active'));
  document.querySelectorAll('.nav-links a').forEach(a=>a.classList.remove('active'));
  const sv = document.getElementById('sub-'+name);
  if(sv) sv.classList.add('active');
  const lnk = document.getElementById('lnk-'+name);
  if(lnk) lnk.classList.add('active');
  document.getElementById('view-inner').scrollTop = 0;
  if(name==='archive') renderArchive();
  if(name==='character') renderCharacter();
}

// ---- ARCHIVE ----
function renderArchive(){
  const grid = document.getElementById('serials-grid');
  grid.innerHTML='';
  serials.forEach((s,i)=>{
    const card = document.createElement('div');
    card.className='serial-card';
    const ch = s.chapters.length;
    card.innerHTML=`
      <div class="s-cover" style="background:${s.color}">
        <h3>${s.title}</h3>
        <p>Griffin Cool</p>
        <button class="s-delete" onclick="deleteSerial(event,${i})" title="Delete serial">×</button>
      </div>
      <div class="s-meta">
        <h4>${s.title}</h4>
        <p>${s.subtitle||'No subtitle'}</p>
        <span class="s-badge">Ongoing · ${ch} ch</span>
      </div>`;
    card.onclick=()=>openSerial(i);
    grid.appendChild(card);
  });
  const add = document.createElement('div');
  add.className='serial-card add-card';
  add.innerHTML=`<div class="s-cover"><span>+</span><p style="color:var(--mist);font-style:italic;font-size:13px">New serial</p></div><div class="s-meta"><h4>Add a work</h4></div>`;
  add.onclick=openNewSerial;
  grid.appendChild(add);
}

function renderCharacter(){
  // compute stats
  const totalSerials = serials.length;
  const totalChapters = serials.reduce((n,s)=>n+s.chapters.length,0);
  const totalWords = serials.reduce((n,s)=>n+s.chapters.reduce((m,ch)=>{
    return m+(ch.prose?ch.prose.trim().split(/\s+/).filter(Boolean).length:0);
  },0),0);

  // stats row
  const statsEl = document.getElementById('char-stats-row');
  statsEl.innerHTML=[
    {val:totalSerials,key:'Serials'},
    {val:totalChapters,key:'Chapters'},
    {val:totalWords.toLocaleString(),key:'Words Written'},
  ].map(s=>`
    <div class="char-stat">
      <div class="char-stat-val">${s.val}</div>
      <div class="char-stat-key">${s.key}</div>
    </div>
  `).join('');

  // library
  const libEl = document.getElementById('char-library');
  if(!serials.length){
    libEl.innerHTML='<p class="char-lib-empty">No works yet. Start a serial in the Archive.</p>';
  } else {
    libEl.innerHTML=serials.map((s,i)=>{
      const ch=s.chapters.length;
      const wc=s.chapters.reduce((n,c)=>n+(c.prose?c.prose.trim().split(/\s+/).filter(Boolean).length:0),0);
      return `<div class="char-lib-row" onclick="showSub('archive');setTimeout(()=>openSerial(${i}),50)">
        <div class="char-lib-dot" style="background:${s.color==='#1A1208'?'var(--sepia)':s.color}"></div>
        <span class="char-lib-title">${s.title}</span>
        <span class="char-lib-meta">${ch} ch · ${wc.toLocaleString()} words</span>
      </div>`;
    }).join('');
  }

  // achievements
  const ACHIEVEMENTS = [
    {icon:'✦',label:'First Word',earned:totalWords>0},
    {icon:'📖',label:'First Chapter',earned:totalChapters>=1},
    {icon:'📚',label:'Three Serials',earned:totalSerials>=3},
    {icon:'🌿',label:'1,000 Words',earned:totalWords>=1000},
    {icon:'🔥',label:'10,000 Words',earned:totalWords>=10000},
    {icon:'🌍',label:'Five Chapters',earned:totalChapters>=5},
  ];
  const achEl=document.getElementById('char-achievements');
  achEl.innerHTML=ACHIEVEMENTS.map(a=>`
    <div class="char-ach${a.earned?' earned':''}">
      <span class="char-ach-icon">${a.icon}</span>
      <span class="char-ach-label">${a.label}</span>
    </div>
  `).join('');
}

function deleteSerial(e, idx){
  e.stopPropagation();
  const s = serials[idx];
  if(!confirm(`Delete "${s.title}"? This cannot be undone.`)) return;
  serials.splice(idx,1);
  save();
  if(activeS===idx){ activeS=null; document.getElementById('ch-panel').classList.remove('open'); }
  else if(activeS!==null && activeS>idx){ activeS--; }
  renderArchive();
}

function openSerial(idx){
  activeS = idx;
  const s = serials[idx];
  const panel = document.getElementById('ch-panel');
  const list = document.getElementById('ch-list');
  document.getElementById('ch-panel-title').textContent = s.title+' — Chapters';
  list.innerHTML='';
  if(!s.chapters.length){
    list.innerHTML='<p style="font-size:14px;color:var(--mist);font-style:italic;padding:1rem 0">No chapters yet.</p>';
  } else {
    s.chapters.forEach((ch,i)=>{
      const wc = ch.prose ? ch.prose.trim().split(/\s+/).filter(Boolean).length : 0;
      const row = document.createElement('div');
      row.className='ch-row';
      row.innerHTML=`<span class="ch-num">${ROMAN[i]||i+1}</span><span class="ch-name">${ch.title||'Untitled Chapter'}</span><span class="ch-wc">${wc} words</span><span class="ch-arr">→</span>`;
      row.onclick=()=>openChapter(idx,i);
      list.appendChild(row);
    });
  }
  panel.classList.add('open');
  panel.scrollIntoView({behavior:'smooth',block:'nearest'});
}

function addChapter(){
  if(activeS===null) return;
  serials[activeS].chapters.push({title:'',prose:'',notes:{ideas:'',world:''}});
  save();
  openChapter(activeS, serials[activeS].chapters.length-1);
}

// ---- WRITER ----
function openChapter(sIdx, cIdx){
  activeS=sIdx; activeCh=cIdx;
  const s=serials[sIdx], ch=s.chapters[cIdx];
  document.getElementById('w-label').textContent=s.title;
  document.getElementById('w-ch-num').textContent='Chapter '+(ROMAN[cIdx]||cIdx+1);
  document.getElementById('w-title-in').value=ch.title||'';
  document.getElementById('w-prose').value=ch.prose||'';
  document.getElementById('n-ideas').value=ch.notes?.ideas||'';
  document.getElementById('n-world').value=ch.notes?.world||'';
  updateWC();
  setMode('write');
  showSub('writer');
}

function setMode(m){
  document.getElementById('write-mode').style.display=m==='write'?'block':'none';
  const nm=document.getElementById('notes-mode');
  nm.style.display='none'; nm.classList.remove('show');
  if(m==='notes'){nm.style.display='block';nm.classList.add('show');}
  document.getElementById('read-mode').style.display=m==='read'?'block':'none';
  ['write','notes','read'].forEach(x=>{
    document.getElementById('bw-'+x).classList.toggle('active',x===m);
  });
  if(m==='read') renderRead();
}

function renderRead(){
  if(activeS===null||activeCh===null) return;
  const s=serials[activeS], ch=s.chapters[activeCh];
  document.getElementById('r-label').textContent=s.title+' · Chapter '+(ROMAN[activeCh]||activeCh+1);
  document.getElementById('r-title').textContent=ch.title||'Untitled';
  const body=document.getElementById('r-body');
  const prose=ch.prose||'';
  body.innerHTML=prose.trim()?'':'<p class="r-empty">Nothing written yet.</p>';
  if(prose.trim()) body.textContent=prose;
}

function updateWC(){
  const p=document.getElementById('w-prose').value;
  const wc=p.trim()===''?0:p.trim().split(/\s+/).filter(Boolean).length;
  document.getElementById('w-wc').textContent=wc.toLocaleString()+' words';
}

function scheduleAutoSave(){
  clearTimeout(saveTimer);
  saveTimer=setTimeout(()=>{
    if(activeS===null||activeCh===null) return;
    serials[activeS].chapters[activeCh].title=document.getElementById('w-title-in').value;
    serials[activeS].chapters[activeCh].prose=document.getElementById('w-prose').value;
    if(!serials[activeS].chapters[activeCh].notes) serials[activeS].chapters[activeCh].notes={};
    serials[activeS].chapters[activeCh].notes.ideas=document.getElementById('n-ideas').value;
    serials[activeS].chapters[activeCh].notes.world=document.getElementById('n-world').value;
    save();
    const s=document.getElementById('nav-save');
    s.classList.add('on');
    setTimeout(()=>s.classList.remove('on'),2000);
  },800);
}

function save(){localStorage.setItem('cm_serials',JSON.stringify(serials))}

// ---- MODAL ----
function openNewSerial(){
  document.getElementById('m-title').value='';
  document.getElementById('m-sub').value='';
  selColor='#1A1208';
  document.querySelectorAll('.swatch').forEach(d=>d.classList.remove('sel'));
  document.querySelector('.swatch').classList.add('sel');
  document.getElementById('modal').classList.add('open');
  setTimeout(()=>document.getElementById('m-title').focus(),80);
}
function closeModal(){document.getElementById('modal').classList.remove('open')}
function pickColor(el){
  selColor=el.dataset.c;
  document.querySelectorAll('.swatch').forEach(d=>d.classList.remove('sel'));
  el.classList.add('sel');
}
function createSerial(){
  const t=document.getElementById('m-title').value.trim();
  if(!t) return;
  serials.push({title:t,subtitle:document.getElementById('m-sub').value.trim(),color:selColor,chapters:[]});
  save();
  closeModal();
  renderArchive();
  openSerial(serials.length-1);
}

// events
document.getElementById('w-prose').addEventListener('input',()=>{updateWC();scheduleAutoSave()});
document.getElementById('w-title-in').addEventListener('input',scheduleAutoSave);
document.getElementById('n-ideas').addEventListener('input',scheduleAutoSave);
document.getElementById('n-world').addEventListener('input',scheduleAutoSave);
document.getElementById('modal').addEventListener('click',function(e){if(e.target===this)closeModal()});
document.getElementById('m-title').addEventListener('keydown',e=>{if(e.key==='Enter')createSerial()});
</script>
</body>
</html>
