<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>The City Magazine — Earthland</title>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400;1,500&family=EB+Garamond:ital,wght@0,400;0,500;1,400;1,500&display=swap" rel="stylesheet">
<style>
*{margin:0;padding:0;box-sizing:border-box}
:root{
  --parchment:#F2E8D5;
  --parchment-dark:#E8D9B8;
  --parchment-deep:#D9C89A;
  --ink:#1A1208;
  --ink-light:#3D2E10;
  --sepia:#8B6914;
  --sepia-light:#B8901E;
  --mist:#C4B89A;
  --forest:#2D4A2D;
  --cream:#FAF4E6;
}
html,body{height:100%;overflow:hidden}
body{background:#060c05;font-family:'EB Garamond',Georgia,serif;color:var(--parchment)}

/* ============================================================
   VIEWS
   ============================================================ */
.view{display:none;position:fixed;inset:0;z-index:1}
.view.active{display:block}

/* ============================================================
   COVER — TREEHOUSE PORTAL
   ============================================================ */
#view-cover{overflow:hidden;background:#060c05}

.forest-scene{position:absolute;inset:0;width:100%;height:100%}

/* sky gradient — transparent now, city SVG handles it */
.forest-sky{
  position:absolute;inset:0;
  background:#05080f;
}

/* CITY SKY SVG */
.city-sky-svg{
  position:absolute;inset:0;width:100%;height:100%;pointer-events:none;z-index:0;
}

/* central light shaft from above */
.light-shaft{
  position:absolute;
  top:0;left:50%;transform:translateX(-50%);
  width:600px;height:85%;
  background:radial-gradient(ellipse at 50% 0%,rgba(190,220,130,0.10) 0%,rgba(150,190,90,0.06) 35%,transparent 75%);
  pointer-events:none;
}
.light-shaft-2{
  position:absolute;
  top:0;left:34%;
  width:280px;height:60%;
  background:radial-gradient(ellipse at 50% 0%,rgba(160,200,100,0.06) 0%,transparent 65%);
  pointer-events:none;
}

/* TREES — left cluster */
.tree{position:absolute;bottom:0;pointer-events:none}

/* foliage blobs via SVG embedded */
.trees-svg{position:absolute;inset:0;width:100%;height:100%;pointer-events:none}

/* ground mist */
.ground-mist{
  position:absolute;bottom:0;left:0;right:0;height:35vh;
  background:linear-gradient(to top,rgba(4,9,3,0.99) 0%,rgba(6,14,4,0.88) 25%,rgba(8,18,5,0.45) 55%,transparent 100%);
  pointer-events:none;z-index:2;
}
.ground-mist-2{
  position:absolute;bottom:0;left:0;right:0;height:200px;
  background:radial-gradient(ellipse 90% 60% at 50% 100%,rgba(20,50,15,0.14) 0%,transparent 70%);
  pointer-events:none;z-index:2;
}

/* TREEHOUSE */
.treehouse{
  position:absolute;
  bottom:0;
  left:50%;
  transform:translateX(-50%);
  width:min(480px, 52vw);
  z-index:5;
  user-select:none;
}

/* main trunk support */
.trunk-l,.trunk-r{
  position:absolute;
  bottom:-90px;
  width:28px;
  background:linear-gradient(to right,#1a0e06,#2e1e0a,#1a0e06);
  border-radius:4px;
  z-index:1;
}
.trunk-l{left:40px;height:140px}
.trunk-r{right:40px;height:160px}

/* platform deck */
.platform{
  position:relative;
  width:100%;
  height:clamp(22px, 2.2vw, 38px);
  margin:0 auto;
  background:linear-gradient(to bottom,#5a3e1e,#3a2810,#2a1c08);
  border-radius:3px 3px 0 0;
  border-top:3px solid #6a4e28;
  z-index:3;
}
.platform::before{
  content:'';position:absolute;
  left:-3%;right:-3%;top:0;height:100%;
  background:linear-gradient(to bottom,#4e3418,#3a2510);
  border-radius:3px;
  z-index:-1;
}
/* platform planks */
.platform-planks{
  position:absolute;top:3px;left:4px;right:4px;bottom:3px;
  display:flex;gap:3px;overflow:hidden;border-radius:1px;
}
.p-plank{flex:1;background:linear-gradient(to bottom,#5e4228,#3e2a12);border-right:1px solid #2a1a08}

/* railing */
.railing{
  position:absolute;top:-clamp(40px,5vw,80px);left:-3%;right:-3%;height:clamp(40px,5vw,80px);
  border-top:4px solid #5a3e1e;
  display:flex;justify-content:space-between;
  padding:0 6px;
  z-index:4;
}
.rail-post{width:4px;height:100%;background:#4a3418;margin-top:-4px}

/* walls */
.walls{
  width:90%;
  height:clamp(200px, 26vw, 420px);
  margin:0 auto;
  background:linear-gradient(160deg,#3e2c14 0%,#2e1e0a 50%,#261808 100%);
  border:2px solid #4a3418;
  border-bottom:none;
  position:relative;
  z-index:3;
  display:flex;align-items:center;justify-content:center;
  gap:clamp(20px, 5vw, 80px);
}
/* wood grain texture lines */
.walls::before{
  content:'';position:absolute;inset:0;
  background:repeating-linear-gradient(90deg,transparent,transparent 28px,rgba(0,0,0,0.07) 28px,rgba(0,0,0,0.07) 30px);
  pointer-events:none;
}

/* windows */
.window{
  width:clamp(60px,8vw,130px);height:clamp(60px,8vw,130px);
  border:3px solid #6a4e28;
  background:rgba(180,150,70,0.08);
  display:grid;grid-template-columns:1fr 1fr;grid-template-rows:1fr 1fr;
  gap:3px;padding:6px;
  position:relative;
  box-shadow:0 0 20px rgba(180,150,60,0.12),inset 0 0 12px rgba(0,0,0,0.3);
}
.w-pane{background:rgba(170,140,65,0.1);border-radius:1px}
.window.lit .w-pane{background:rgba(210,175,80,0.2)}
.window.lit{box-shadow:0 0 30px rgba(200,165,70,0.3),inset 0 0 14px rgba(0,0,0,0.2)}

/* THE DOOR — portal */
.door-wrap{
  position:relative;
  display:flex;flex-direction:column;align-items:center;
}
.door{
  width:clamp(70px,9vw,145px);height:clamp(105px,13.5vw,218px);
  background:linear-gradient(to bottom,#2a1a08 0%,#1a0e04 100%);
  border:3px solid #9a7a3a;
  border-radius:6px 6px 0 0;
  position:relative;
  cursor:pointer;
  overflow:visible;
  transition:all 0.3s ease;
  box-shadow:
    0 0 18px 6px rgba(220,175,70,0.45),
    0 0 50px 18px rgba(190,145,45,0.22),
    0 0 90px 35px rgba(160,120,30,0.10);
  animation:door-pulse 2.8s ease-in-out infinite alternate;
}
@keyframes door-pulse{
  0%{
    box-shadow:0 0 14px 5px rgba(220,175,70,0.40),0 0 40px 15px rgba(190,145,45,0.18),0 0 80px 30px rgba(160,120,30,0.09);
    border-color:#9a7a3a;
  }
  100%{
    box-shadow:0 0 28px 10px rgba(240,200,90,0.60),0 0 70px 28px rgba(210,165,60,0.30),0 0 120px 50px rgba(180,140,40,0.14);
    border-color:#c0a050;
  }
}
.door-glow{
  position:absolute;inset:0;
  background:radial-gradient(ellipse at 50% 55%,rgba(240,210,120,0.55) 0%,rgba(205,165,75,0.35) 40%,rgba(160,120,40,0.12) 70%,transparent 100%);
  opacity:1;
  animation:glow-breathe 2.8s ease-in-out infinite alternate;
  pointer-events:none;
}
@keyframes glow-breathe{
  0%{opacity:0.7}
  100%{opacity:1}
}
/* warm spill light onto platform below the door */
.door-wrap::after{
  content:'';
  position:absolute;
  bottom:-30px;left:50%;transform:translateX(-50%);
  width:200px;height:35px;
  background:radial-gradient(ellipse at 50% 0%,rgba(220,180,70,0.30) 0%,transparent 70%);
  pointer-events:none;
}
.door-panel-top{
  position:absolute;top:10%;left:10%;right:10%;height:33%;
  border:2px solid #6a5028;border-radius:3px 3px 0 0;
}
.door-panel-bot{
  position:absolute;top:50%;left:10%;right:10%;bottom:8%;
  border:2px solid #6a5028;border-radius:0 0 3px 3px;
}
.door-knob{
  position:absolute;right:12%;top:50%;transform:translateY(-50%);
  width:clamp(6px,0.8vw,12px);height:clamp(6px,0.8vw,12px);border-radius:50%;
  background:#c09040;
  box-shadow:0 0 6px rgba(220,180,80,0.8),0 0 12px rgba(200,160,60,0.4);
  animation:knob-glow 2.8s ease-in-out infinite alternate;
}
@keyframes knob-glow{
  0%{box-shadow:0 0 4px rgba(220,180,80,0.7),0 0 8px rgba(200,160,60,0.3)}
  100%{box-shadow:0 0 8px rgba(240,200,100,1),0 0 18px rgba(220,180,80,0.6)}
}
.door:hover{
  box-shadow:
    0 0 35px 14px rgba(240,200,90,0.70),
    0 0 80px 35px rgba(210,165,55,0.38),
    0 0 140px 60px rgba(180,140,35,0.18);
  border-color:#d4b060;
  animation:none;
}

/* door open state */
.door.open{
  transform-origin:left center;
  animation:door-open 0.9s cubic-bezier(0.4,0,0.2,1) forwards;
}
@keyframes door-open{
  0%{transform:perspective(600px) rotateY(0deg)}
  100%{transform:perspective(600px) rotateY(-75deg)}
}
.door-light{
  position:absolute;
  top:0;left:0;
  width:clamp(70px,9vw,145px);height:clamp(105px,13.5vw,218px);
  border-radius:6px 6px 0 0;
  background:radial-gradient(ellipse at 50% 50%,rgba(230,200,120,0.95) 0%,rgba(200,165,80,0.7) 40%,rgba(160,120,40,0.2) 80%,transparent 100%);
  opacity:0;
  pointer-events:none;
  z-index:10;
  transition:opacity 0.3s ease;
}
.door-light.show{opacity:1;animation:light-pulse 2s ease-in-out infinite alternate}
@keyframes light-pulse{0%{opacity:0.85}100%{opacity:1}}

/* door step */
.door-step{
  width:clamp(80px,11vw,175px);height:clamp(9px,1.1vw,18px);
  background:linear-gradient(to bottom,#5a3e1e,#3a2510);
  border-radius:0 0 3px 3px;
  border:2px solid #4a3018;border-top:none;
}

/* ROOF — SVG-based, always congruent with wall width */
.roof-wrap{
  position:relative;
  width:100%;
  z-index:4;
}
.roof-svg{
  width:108%;
  margin-left:-4%;
  display:block;
  overflow:visible;
  filter:drop-shadow(0 -3px 14px rgba(0,0,0,0.75));
}

/* chimney */
.chimney{
  position:absolute;
  top:clamp(-50px,-6vw,-30px);right:clamp(80px,12vw,200px);
  width:clamp(26px,3.2vw,52px);height:clamp(48px,6vw,96px);
  background:linear-gradient(to right,#2e1e0a,#3e2a10,#2e1e0a);
  border:2px solid #4a3418;
  z-index:3;
}
.chimney::after{
  content:'';
  position:absolute;bottom:100%;left:-4px;right:-4px;
  height:8px;
  background:#2a1808;
  border:1px solid #3a2810;
}

/* smoke puffs */
.smoke{
  position:absolute;
  border-radius:50%;
  background:rgba(80,70,55,0.15);
  pointer-events:none;
  animation:rise 4s ease-out infinite;
}
@keyframes rise{
  0%{opacity:0;transform:translateY(0) scale(0.3)}
  20%{opacity:0.6}
  80%{opacity:0.2}
  100%{opacity:0;transform:translateY(-60px) scale(1.8)}
}

/* SIGN — hangs on left side of building */
.roof-sign{
  position:absolute;
  left:6%;
  bottom:clamp(-54px,-6.5vw,-34px);
  z-index:10;
  pointer-events:none;
}
.sign-rope-l,.sign-rope-r{
  position:absolute;
  top:0;width:1px;background:rgba(160,120,60,0.7);
  height:clamp(8px,1vw,14px);
  transform:translateY(-100%);
}
.sign-rope-l{left:22%}
.sign-rope-r{left:68%}
.roof-sign-text{
  display:block;
  font-family:'Cormorant Garamond',serif;
  font-size:clamp(9px,1.2vw,18px);
  font-weight:400;
  font-style:italic;
  color:rgba(240,220,160,0.95);
  letter-spacing:0.09em;
  white-space:nowrap;
  background:linear-gradient(to bottom,#3a2810,#251806);
  border:1px solid #6a4e28;
  border-radius:2px;
  padding:clamp(2px,0.35vw,5px) clamp(7px,1vw,16px);
  text-shadow:0 0 14px rgba(220,190,80,0.7),0 1px 3px rgba(0,0,0,0.9);
  box-shadow:0 2px 8px rgba(0,0,0,0.5),0 0 12px rgba(200,165,60,0.12);
  animation:sign-glow 3s ease-in-out infinite alternate;
}
@keyframes sign-glow{
  0%{text-shadow:0 0 12px rgba(220,190,80,0.6),0 1px 3px rgba(0,0,0,0.9)}
  100%{text-shadow:0 0 22px rgba(240,210,100,0.9),0 0 44px rgba(220,185,60,0.4),0 1px 3px rgba(0,0,0,0.9)}
}

/* BRIDGE */
.bridge-wrap{
  position:absolute;
  bottom:0;left:50%;transform:translateX(-50%);
  width:200px;
  z-index:4;
  pointer-events:none;
}
.bridge-svg{width:100%;height:auto}

/* ROPE LINES left/right */
.rope-anchor{
  position:absolute;
  z-index:4;
  pointer-events:none;
}

/* TEXT OVERLAY */
.cover-title{
  position:absolute;
  top:3vh;left:50%;
  transform:translateX(-50%);
  text-align:center;
  z-index:10;
  pointer-events:none;
  width:360px;
}
.cover-eyebrow{
  font-family:'EB Garamond',serif;
  font-size:11px;letter-spacing:0.25em;text-transform:uppercase;
  color:rgba(180,160,100,0.55);margin-bottom:0.6rem;
}
.cover-mag{
  font-family:'Cormorant Garamond',serif;
  font-size:clamp(28px,3.5vw,52px);font-weight:300;font-style:italic;
  color:rgba(230,215,170,0.88);
  line-height:1.05;
  text-shadow:0 2px 40px rgba(150,120,40,0.35);
}
.cover-sub{
  font-family:'EB Garamond',serif;
  font-size:14px;font-style:italic;
  color:rgba(160,140,90,0.55);
  margin-top:0.6rem;letter-spacing:0.05em;
}

/* enter prompt near door */
.door-prompt{
  position:absolute;
  z-index:10;
  left:50%;
  transform:translateX(-50%);
  font-family:'EB Garamond',serif;
  font-size:12px;letter-spacing:0.18em;
  text-transform:uppercase;
  color:rgba(200,175,100,0.5);
  text-align:center;
  pointer-events:none;
  transition:opacity 0.3s;
  white-space:nowrap;
}

/* PAGE TURN TRANSITION */
.portal-flash{
  position:fixed;inset:0;
  pointer-events:none;
  z-index:999;
  perspective:1400px;
  display:none;
}
.portal-flash.go{display:block;pointer-events:all}

.page-turn-leaf{
  position:absolute;
  top:0;left:0;
  width:100%;height:100%;
  background:var(--cream);
  transform-origin:left center;
  transform:rotateY(90deg);
  backface-visibility:hidden;
  box-shadow:-8px 0 40px rgba(0,0,0,0.25);
  animation:page-turn-in 0.85s cubic-bezier(0.4,0,0.2,1) forwards;
}
@keyframes page-turn-in{
  0%{transform:rotateY(90deg);opacity:0.7}
  40%{opacity:1}
  100%{transform:rotateY(0deg)}
}
.page-turn-leaf::before{
  content:'';
  position:absolute;inset:0;
  background:radial-gradient(ellipse 80% 60% at 50% 50%,rgba(242,232,213,1) 0%,rgba(232,217,184,1) 100%);
}
.page-turn-leaf::after{
  content:'';
  position:absolute;top:0;left:0;width:60px;height:100%;
  background:linear-gradient(to right,rgba(100,70,20,0.18) 0%,transparent 100%);
  pointer-events:none;
}

/* FIREFLIES */
.firefly{
  position:absolute;
  width:3px;height:3px;border-radius:50%;
  background:rgba(210,230,130,0.9);
  animation:ff linear infinite;
  pointer-events:none;
  z-index:3;
}
@keyframes ff{
  0%{opacity:0;transform:translate(0,0)}
  15%{opacity:0.9}
  85%{opacity:0.6}
  100%{opacity:0;transform:translate(var(--fdx),var(--fdy))}
}

/* ============================================================
   INNER SITE (after door opens)
   ============================================================ */
#view-inner{
  background:var(--parchment);
  overflow-y:auto;
  overflow-x:hidden;
}

nav{
  background:var(--ink);
  padding:0 2rem;
  display:flex;align-items:center;justify-content:space-between;
  height:50px;position:sticky;top:0;z-index:100;
}
.nav-title{
  font-family:'Cormorant Garamond',serif;font-size:17px;font-weight:600;
  color:var(--parchment);letter-spacing:0.12em;text-transform:uppercase;cursor:pointer;
}
.nav-links{display:flex;gap:1.5rem;list-style:none;align-items:center}
.nav-links a{
  color:var(--mist);text-decoration:none;font-family:'EB Garamond',serif;
  font-size:13px;letter-spacing:0.08em;text-transform:uppercase;cursor:pointer;transition:color 0.2s;
}
.nav-links a:hover,.nav-links a.active{color:var(--parchment)}
.nav-save{font-size:11px;color:var(--mist);font-style:italic;font-family:'EB Garamond',serif;opacity:0;transition:opacity 0.3s}
.nav-save.on{opacity:1}

/* sub views */
.sub-view{display:none}
.sub-view.active{display:block}

/* ---- ARCHIVE ---- */
.archive-header{
  border-bottom:1px solid var(--parchment-deep);
  padding:2.5rem 3rem 1.5rem;background:var(--cream);
  display:flex;align-items:center;justify-content:space-between;
}
.archive-title{font-family:'Cormorant Garamond',serif;font-size:36px;font-weight:400;font-style:italic;color:var(--ink)}
.btn-sm{
  background:transparent;border:1px solid var(--sepia);color:var(--sepia);
  font-family:'EB Garamond',serif;font-size:12px;letter-spacing:0.1em;text-transform:uppercase;
  padding:0.45rem 1.1rem;cursor:pointer;transition:all 0.2s;
}
.btn-sm:hover{background:var(--sepia);color:var(--ink)}
.serials-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(180px,1fr));gap:1.75rem;padding:2.5rem 3rem}
.serial-card{cursor:pointer;transition:transform 0.2s}
.serial-card:hover{transform:translateY(-3px)}
.s-cover{
  width:100%;aspect-ratio:3/4;margin-bottom:0.75rem;
  display:flex;flex-direction:column;align-items:center;justify-content:center;
  padding:1.25rem;border:1.5px solid rgba(255,255,255,0.08);
  position:relative;
}
.s-cover h3{font-family:'Cormorant Garamond',serif;font-size:17px;font-weight:400;font-style:italic;text-align:center;line-height:1.2;color:var(--parchment)}
.s-cover p{font-size:10px;letter-spacing:0.1em;text-transform:uppercase;margin-top:0.5rem;color:var(--sepia-light);text-align:center}
.s-meta h4{font-family:'Cormorant Garamond',serif;font-size:16px;font-weight:500;color:var(--ink);margin-bottom:0.2rem}
.s-meta p{font-size:12px;color:var(--sepia);font-style:italic}
.s-badge{display:inline-block;font-size:10px;letter-spacing:0.1em;text-transform:uppercase;padding:2px 6px;border:1px solid var(--forest);color:var(--forest);margin-top:0.4rem;font-family:'EB Garamond',serif}
.add-card .s-cover{border:2px dashed var(--mist);background:transparent;flex-direction:column;gap:0.4rem}
.add-card .s-cover span{font-size:26px;color:var(--mist)}
.add-card .s-meta h4{color:var(--mist)}

/* delete button on serial cover */
.s-delete{
  position:absolute;top:6px;right:6px;
  width:20px;height:20px;
  background:rgba(26,18,8,0.55);
  border:1px solid rgba(180,140,60,0.3);
  border-radius:50%;
  color:rgba(200,175,120,0.7);
  font-size:14px;line-height:1;
  cursor:pointer;
  display:flex;align-items:center;justify-content:center;
  opacity:0;
  transition:opacity 0.15s,background 0.15s,color 0.15s;
  padding:0;
}
.s-delete:hover{background:rgba(120,30,20,0.75);border-color:rgba(220,80,60,0.5);color:#fff}
.serial-card:hover .s-delete{opacity:1}

/* chapter panel */
.ch-panel{background:var(--cream);border-top:1px solid var(--parchment-deep);padding:2rem 3rem 3rem;display:none}
.ch-panel.open{display:block}
.ch-panel-head{
  font-family:'Cormorant Garamond',serif;font-size:20px;font-style:italic;color:var(--ink-light);
  margin-bottom:1.25rem;display:flex;align-items:center;justify-content:space-between;
}
.ch-row{
  display:flex;align-items:center;gap:1rem;padding:0.6rem 0;
  border-bottom:1px solid var(--parchment);cursor:pointer;transition:padding-left 0.12s;
}
.ch-row:hover{padding-left:0.5rem;background:rgba(139,105,20,0.04)}
.ch-num{font-size:11px;color:var(--mist);font-family:'EB Garamond',serif;letter-spacing:0.1em;min-width:28px}
.ch-name{font-family:'Cormorant Garamond',serif;font-size:17px;color:var(--ink);flex:1}
.ch-wc{font-size:11px;color:var(--mist);font-family:'EB Garamond',serif}
.ch-arr{color:var(--sepia);font-size:13px;opacity:0}
.ch-row:hover .ch-arr{opacity:1}

/* ---- WRITER ---- */
.writer-bar{
  background:var(--parchment-dark);border-bottom:1px solid var(--parchment-deep);
  padding:0 2rem;height:44px;display:flex;align-items:center;gap:1.5rem;
}
.w-back{font-size:12px;letter-spacing:0.1em;text-transform:uppercase;color:var(--sepia);cursor:pointer;font-family:'EB Garamond',serif;background:none;border:none;padding:0}
.w-back:hover{color:var(--ink)}
.w-div{width:1px;height:20px;background:var(--parchment-deep)}
.w-label{font-family:'EB Garamond',serif;font-size:13px;color:var(--ink-light);font-style:italic;flex:1}
.w-wc{font-size:11px;color:var(--mist);font-family:'EB Garamond',serif}
.w-modes{display:flex;gap:0.5rem}
.w-mode{font-size:11px;letter-spacing:0.1em;text-transform:uppercase;color:var(--mist);border:1px solid transparent;background:none;padding:3px 10px;cursor:pointer;font-family:'EB Garamond',serif;transition:all 0.15s}
.w-mode.active{border-color:var(--sepia);color:var(--sepia)}
.w-mode:hover{color:var(--ink)}
.w-title-area{max-width:700px;margin:2.5rem auto 0;padding:0 2rem}
.w-ch-num{font-size:11px;letter-spacing:0.2em;text-transform:uppercase;color:var(--mist);font-family:'EB Garamond',serif;margin-bottom:0.5rem;text-align:center}
.w-title-in{
  font-family:'Cormorant Garamond',serif;font-size:clamp(26px,4vw,40px);
  font-weight:400;font-style:italic;color:var(--ink);background:transparent;
  border:none;border-bottom:1px solid transparent;width:100%;text-align:center;
  outline:none;padding:0.25rem 0;transition:border-color 0.2s;line-height:1.2;
}
.w-title-in:focus{border-bottom-color:var(--parchment-deep)}
.w-title-in::placeholder{color:var(--mist)}
.w-rule{display:flex;align-items:center;gap:1rem;margin:1.5rem auto;max-width:700px;padding:0 2rem}
.w-rule::before,.w-rule::after{content:'';flex:1;height:1px;background:var(--parchment-deep)}
.w-orn{color:var(--sepia);font-size:15px}
.w-prose-wrap{max-width:700px;margin:0 auto;padding:0 2rem 6rem}
.w-prose{
  font-family:'EB Garamond',serif;font-size:20px;line-height:1.9;color:var(--ink);
  background:transparent;border:none;outline:none;width:100%;min-height:60vh;
  resize:none;caret-color:var(--sepia);
}
.w-prose::placeholder{color:var(--mist);font-style:italic}

/* notes */
.notes-wrap{max-width:700px;margin:0 auto;padding:1.5rem 2rem 6rem;display:none}
.notes-wrap.show{display:block}
.n-label{font-size:11px;letter-spacing:0.15em;text-transform:uppercase;color:var(--mist);font-family:'EB Garamond',serif;margin-bottom:0.6rem}
.n-in{
  font-family:'EB Garamond',serif;font-size:17px;line-height:1.8;color:var(--ink-light);
  background:transparent;border:none;border-left:2px solid var(--parchment-deep);
  padding-left:1rem;outline:none;width:100%;min-height:40vh;resize:none;
}
.n-in::placeholder{color:var(--mist);font-style:italic}

/* read mode */
#read-mode{display:none;background:var(--cream);min-height:calc(100vh - 94px)}
.r-wrap{max-width:660px;margin:0 auto;padding:3.5rem 2rem 6rem}
.r-label{font-size:11px;letter-spacing:0.2em;text-transform:uppercase;color:var(--mist);text-align:center;margin-bottom:0.75rem;font-family:'EB Garamond',serif}
.r-title{font-family:'Cormorant Garamond',serif;font-size:clamp(26px,4vw,42px);font-weight:400;font-style:italic;color:var(--ink);text-align:center;line-height:1.15;margin-bottom:0.4rem}
.r-by{text-align:center;font-size:13px;color:var(--sepia);font-style:italic;margin-bottom:2.5rem}
.r-rule{display:flex;align-items:center;gap:1rem;margin-bottom:2.5rem}
.r-rule::before,.r-rule::after{content:'';flex:1;height:1px;background:var(--parchment-deep)}
.r-orn{color:var(--sepia);font-size:16px}
.r-body{font-family:'EB Garamond',serif;font-size:20px;line-height:1.9;color:var(--ink);white-space:pre-wrap;word-break:break-word}
.r-empty{font-size:15px;color:var(--mist);font-style:italic;text-align:center;padding:3rem 0}

/* ---- CHARACTER ---- */
.char-header{
  background:var(--ink);
  padding:2.5rem 3rem 2rem;
  border-bottom:1px solid rgba(255,255,255,0.06);
}
.char-identity{display:flex;align-items:center;gap:1.5rem}
.char-avatar{
  width:64px;height:64px;border-radius:50%;
  background:linear-gradient(135deg,var(--sepia) 0%,var(--ink-light) 100%);
  border:2px solid var(--sepia-light);
  display:flex;align-items:center;justify-content:center;
  font-family:'Cormorant Garamond',serif;font-size:28px;font-weight:500;
  color:var(--parchment);
  flex-shrink:0;
}
.char-name{
  font-family:'Cormorant Garamond',serif;font-size:28px;font-weight:400;font-style:italic;
  color:var(--parchment);line-height:1.1;
}
.char-handle{
  font-family:'EB Garamond',serif;font-size:13px;
  color:var(--mist);letter-spacing:0.06em;margin-top:0.2rem;
}

.char-body{padding:2.5rem 3rem 5rem;max-width:900px}

.char-section{margin-bottom:2.75rem}
.char-section-label{
  font-family:'EB Garamond',serif;font-size:11px;letter-spacing:0.22em;
  text-transform:uppercase;color:var(--mist);margin-bottom:1rem;
  border-bottom:1px solid var(--parchment-deep);padding-bottom:0.4rem;
}

/* stats */
.char-stats-row{display:flex;gap:1.25rem;flex-wrap:wrap}
.char-stat{
  background:var(--cream);border:1px solid var(--parchment-deep);
  padding:1rem 1.5rem;min-width:120px;text-align:center;
}
.char-stat-val{
  font-family:'Cormorant Garamond',serif;font-size:36px;font-weight:300;
  color:var(--ink);line-height:1;
}
.char-stat-key{
  font-family:'EB Garamond',serif;font-size:11px;letter-spacing:0.14em;
  text-transform:uppercase;color:var(--mist);margin-top:0.3rem;
}

/* library */
.char-library{display:flex;flex-direction:column;gap:0.5rem}
.char-lib-row{
  display:flex;align-items:center;gap:1rem;
  padding:0.65rem 0;border-bottom:1px solid var(--parchment);
  cursor:pointer;transition:padding-left 0.12s;
}
.char-lib-row:hover{padding-left:0.4rem}
.char-lib-dot{
  width:8px;height:8px;border-radius:50%;flex-shrink:0;
}
.char-lib-title{
  font-family:'Cormorant Garamond',serif;font-size:17px;color:var(--ink);flex:1;
}
.char-lib-meta{
  font-family:'EB Garamond',serif;font-size:12px;color:var(--mist);
}
.char-lib-empty{
  font-family:'EB Garamond',serif;font-size:15px;color:var(--mist);
  font-style:italic;padding:0.5rem 0;
}

/* achievements */
.char-achievements{display:flex;flex-wrap:wrap;gap:0.75rem}
.char-ach{
  display:flex;align-items:center;gap:0.6rem;
  background:var(--cream);border:1px solid var(--parchment-deep);
  padding:0.55rem 0.9rem;
  opacity:0.45;
}
.char-ach.earned{opacity:1;border-color:var(--sepia-light)}
.char-ach-icon{font-size:16px;line-height:1}
.char-ach-label{
  font-family:'EB Garamond',serif;font-size:13px;color:var(--ink-light);
  letter-spacing:0.04em;
}

/* ROOF SIGN — The City Magazine */
.roof-sign{
  position:absolute;
  bottom:clamp(-18px,-2.2vw,-8px);
  left:50%;transform:translateX(-50%);
  z-index:10;
  text-align:center;
  pointer-events:none;
  white-space:nowrap;
}
.roof-sign-text{
  display:inline-block;
  font-family:'Cormorant Garamond',serif;
  font-size:clamp(13px,1.8vw,28px);
  font-weight:400;
  font-style:italic;
  color:rgba(240,220,160,0.95);
  letter-spacing:0.12em;
  text-shadow:
    0 0 20px rgba(220,190,80,0.8),
    0 0 50px rgba(200,165,50,0.4),
    0 2px 4px rgba(0,0,0,0.9);
  animation:sign-glow 3s ease-in-out infinite alternate;
}
@keyframes sign-glow{
  0%{text-shadow:0 0 16px rgba(220,190,80,0.7),0 0 40px rgba(200,165,50,0.3),0 2px 4px rgba(0,0,0,0.9)}
  100%{text-shadow:0 0 28px rgba(240,210,100,0.95),0 0 70px rgba(220,185,60,0.55),0 2px 4px rgba(0,0,0,0.9)}
}

/* DOOR SIGN — Come on in! */
.door-sign{
  margin-top:clamp(6px,0.8vw,14px);
  text-align:center;
  pointer-events:none;
  position:relative;
}
.door-sign-text{
  display:inline-block;
  font-family:'EB Garamond',serif;
  font-size:clamp(9px,1.1vw,17px);
  font-style:italic;
  color:rgba(210,185,110,0.9);
  letter-spacing:0.08em;
  background:linear-gradient(to bottom,#3a2810,#281a06);
  border:1px solid #6a4e28;
  border-radius:2px;
  padding:clamp(2px,0.3vw,5px) clamp(6px,0.9vw,14px);
  box-shadow:0 2px 8px rgba(0,0,0,0.6),0 0 14px rgba(200,165,60,0.2);
}
.door-sign::before,.door-sign::after{
  content:'';
  position:absolute;
  top:clamp(-8px,-0.9vw,-4px);
  width:1px;
  height:clamp(6px,0.8vw,12px);
  background:rgba(160,120,60,0.7);
}
.door-sign::before{left:28%}
.door-sign::after{right:28%}

.modal-bg{
  display:none;position:fixed;inset:0;background:rgba(26,18,8,0.72);
  z-index:200;align-items:center;justify-content:center;
}
.modal-bg.open{display:flex}
.modal{background:var(--cream);border:1px solid var(--parchment-deep);padding:2.5rem;width:min(460px,90vw);position:relative}
.modal h3{font-family:'Cormorant Garamond',serif;font-size:26px;font-style:italic;margin-bottom:1.5rem;color:var(--ink)}
.m-field{margin-bottom:1.1rem}
.m-field label{display:block;font-size:11px;letter-spacing:0.15em;text-transform:uppercase;color:var(--mist);font-family:'EB Garamond',serif;margin-bottom:0.35rem}
.m-field input{width:100%;background:var(--parchment);border:1px solid var(--parchment-deep);color:var(--ink);font-family:'EB Garamond',serif;font-size:16px;padding:0.55rem 0.7rem;outline:none;transition:border-color 0.2s}
.m-field input:focus{border-color:var(--sepia)}
.swatches{display:flex;gap:0.6rem;flex-wrap:wrap;margin-top:0.25rem}
.swatch{width:26px;height:26px;cursor:pointer;border:2px solid transparent;transition:border-color 0.15s}
.swatch.sel{border-color:var(--sepia-light)}
.m-btns{display:flex;gap:0.75rem;justify-content:flex-end;margin-top:1.5rem}
.m-btn{font-family:'EB Garamond',serif;font-size:12px;letter-spacing:0.1em;text-transform:uppercase;padding:0.55rem 1.4rem;cursor:pointer;border:1px solid var(--sepia);background:transparent;color:var(--sepia);transition:all 0.2s}
.m-btn:hover{background:var(--sepia);color:var(--ink)}
.m-btn.sec{border-color:var(--mist);color:var(--mist)}
.m-btn.sec:hover{background:var(--mist);color:var(--ink)}
.m-close{position:absolute;top:1rem;right:1.25rem;background:none;border:none;font-size:20px;color:var(--mist);cursor:pointer}
.m-close:hover{color:var(--ink)}
</style>
